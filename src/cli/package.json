{
  "name": "mcp-scout-cli",
  "version": "0.1.0",
  "description": "MCP Scout CLI - Discover & Install MCP Servers",
  "bin": {
    "mcp-scout": "./dist/src/main.js"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/src/main.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "sync": "tsx src/sync.ts",
    "pack": "npm pack --dry-run"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "ora": "^8.0.1",
    "prompts": "^2.4.2",
    "fs-extra": "^11.2.0",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/prompts": "^2.4.9",
    "@types/fs-extra": "^11.0.4",
    "tsx": "^4.15.1",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.14.0",
    "@typescript-eslint/parser": "^7.14.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
